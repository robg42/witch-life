# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/reading
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/reading

# Supabase (Postgres + RLS; Supabase Auth disabled — Clerk handles auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-side only — never expose)
ANTHROPIC_API_KEY=

# Stripe (Phase 6)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
