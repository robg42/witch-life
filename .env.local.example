# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local`.

# Clerk (auth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/reading
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/reading

# Supabase (Postgres + RLS; Supabase Auth disabled — Clerk handles auth)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (server-side only — never expose). The model is hardcoded
# in lib/anthropic.ts and lib/reports.ts — there is no env override.
ANTHROPIC_API_KEY=

# Stripe (Phase 6)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs — create one Product per subscription interval and
# one Product per report, then paste the price_xxx IDs here.
STRIPE_PRICE_SUB_MONTHLY=
STRIPE_PRICE_SUB_YEARLY=
STRIPE_PRICE_REPORT_NATAL=
STRIPE_PRICE_REPORT_YEAR_AHEAD=
STRIPE_PRICE_REPORT_SATURN_RETURN=
STRIPE_PRICE_REPORT_ECLIPSE_SEASON=

# Optional: lets server-rendered checkout know the canonical site URL
# when no `Origin` header is present (e.g. for Stripe webhook redirects).
NEXT_PUBLIC_SITE_URL=
